# xml generation
# Generates ../build/project-html5.hxml with machine-local Kha paths.
--cmd node prepare-kha-hxml.js

--next
../build/project-html5.hxml
-cp ../libs/slog/src
--macro include('s')
--no-output
-dce no
-D doc-gen
-xml build/api.xml

# html generation
--next
--cmd if exist "build/html/pages" rd /s /q "build/html/pages"

--next
--cmd haxelib run dox -i build -o build/html/pages -in "s|slog" --title "sengine API" -D version 1.0.0a -D description "sengine libraries APIs" -D source-path https://github.com/selibs/sengine/tree/main/src
